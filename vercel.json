{
  "installCommand": "npm install && npm --prefix frontend install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
